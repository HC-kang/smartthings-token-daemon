{
  "name": "smartthings-token-daemon",
  "version": "0.1.0",
  "description": "Long-running daemon that refreshes SmartThings OAuth tokens and serves fresh access tokens over HTTP.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "bootstrap": "bun run scripts/bootstrap.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  }
}
