# SmartThings OAuth In-App credentials
SMARTTHINGS_CLIENT_ID=
SMARTTHINGS_CLIENT_SECRET=

# Token storage paths
TOKEN_FILE_PATH=./data/tokens.json
TOKEN_BACKUP_PATH=./data/tokens.backup.json

# HTTP bind
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8787

# Refresh policy
REFRESH_THRESHOLD_MINUTES=120
REFRESH_INTERVAL_HOURS=12

# Optional: require Authorization: Bearer <token> on /token and /refresh
LOCAL_BEARER_TOKEN=

# Optional: Discord webhook for refresh failure alerts
DISCORD_WEBHOOK_URL=
